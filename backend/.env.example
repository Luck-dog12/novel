# 后端直接调用工作流域名（方式二）
COZE_WORKFLOW_BASE_URL=https://433c4ef6-4399-4953-9946-5a356f124dbc.dev.coze.site
# 工作流执行路径
COZE_WORKFLOW_RUN_PATH=/run
# 直连域名调用一般无需鉴权，留空即可
COZE_WORKFLOW_TOKEN=
# true 时后端流式接口内部强制走同步回退
COZE_FORCE_SYNC_FOR_STREAM=true
# stream 未产出 final_document 时是否回退 run
COZE_STREAM_FALLBACK_TO_RUN=true
# 生成失败时是否返回 mock 文本
ENABLE_MOCK_FALLBACK=false
# 连接 Coze Bridge 超时（毫秒）
COZE_CONNECT_TIMEOUT_MS=15000
# 请求总超时（毫秒）
COZE_REQUEST_TIMEOUT_MS=300000
# Socket 读写超时（毫秒）
COZE_SOCKET_TIMEOUT_MS=300000
# SSE 心跳间隔（毫秒）
STREAM_HEARTBEAT_INTERVAL_MS=10000
# 兼容旧配置：后端到 Bridge 的 Bearer 鉴权（可留空）
COZE_BRIDGE_TOKEN=
# Coze OpenAPI 基础地址（中国区）
COZE_API_BASE=https://api.coze.cn
# OAuth 应用 Client ID（通常形如 xxx.app.coze）
COZE_OAUTH_CLIENT_ID=replace_me.app.coze
# OAuth 应用 Client Secret
COZE_OAUTH_CLIENT_SECRET=replace_me
# OAuth 回调地址，需与 Coze 平台配置完全一致（本机联调示例）
COZE_OAUTH_REDIRECT_URL=http://127.0.0.1:8080/api/v1/oauth/coze/callback
# 可选：Bridge 回调后落盘 token 的 .env 文件路径（默认 backend/.env）
COZE_ENV_FILE=
# 首次授权码（可留空，走回调接口注入）
COZE_OAUTH_CODE=
# 可选 state 校验值（防 CSRF）
COZE_OAUTH_EXPECTED_STATE=
# 可选 access_token（已有时可直接填）
COZE_OAUTH_ACCESS_TOKEN=
# 可选 refresh_token（用于自动续期）
COZE_OAUTH_REFRESH_TOKEN=
# access_token 过期时间（Unix 秒）
COZE_OAUTH_EXPIRES_AT=0
# Coze 发布工作流 ID
COZE_WORKFLOW_ID=replace_me
# 可选 Bot ID（关联场景时使用）
COZE_BOT_ID=
# 可选 App ID（关联场景时使用）
COZE_APP_ID=
# Bridge 透传给 Coze 的默认用户标识
COZE_BRIDGE_USER_ID=novel-backend
# 应用加密密钥
APP_SECRET_KEY=replace_me
# 是否强依赖外部数据库（本机联调建议 false）
REQUIRE_DB=true
# 数据库连接串
DB_URL=jdbc:mysql://<db-host>:3306/<db-name>?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&useSSL=false
# 数据库用户名
DB_USER=replace_me
# 数据库密码
DB_PASSWORD=replace_me
# 连接池大小
DB_POOL_SIZE=10
# 文件上传目录
UPLOAD_DIR=uploads
